// 1. Configuração do Gerador do Cliente Prisma (Padrão de Indústria)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// 🔥 1. ADICIONADO: Níveis de acesso válidos para o Controlo de Acessos (RBAC)
enum Role {
  ADMIN
  PT
  GUEST
}

// Definição dos modelos de dados

model UserAdmin {
  id             Int       @id @default(autoincrement())
  email          String    @unique // Alterado de username para email para o fluxo JWT convencional
  nome           String    // Nome do utilizador para exibir na Sidebar/Dashboard
  passwordHash   String    @map("password_hash")
  
  // 🔥 2. ADICIONADO: Define as permissões do utilizador (Por padrão é PT)
  role           Role      @default(PT)

  createdAt      DateTime  @default(now()) @map("created_at")
  lastLogin      DateTime? @map("last_login")
  failedAttempts Int       @default(0) @map("failed_attempts")
  isActive       Boolean   @default(true) @map("is_active")

  students       Student[]

  @@map("users_admin")
}

model Student {
  id            Int            @id @default(autoincrement())
  userAdminId   Int            @map("user_admin_id") // 🔥 Liga este aluno ao seu PT criador
  fullName      String         @map("full_name")
  phoneNumber   String         @map("phone_number")
  status        String         @default("Ativo")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  userAdmin     UserAdmin      @relation(fields: [userAdminId], references: [id], onDelete: Cascade)

  trainingPlans TrainingPlan[]
  whatsappLogs  WhatsappLog[]
  weightLogs    WeightLog[]

  @@map("students")
}

model TrainingPlan {
  id        Int        @id @default(autoincrement())
  studentId Int        @map("student_id")
  notes     String?    @db.Text
  createdAt DateTime   @default(now()) @map("created_at")

  student   Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exercises TrainingExercise[]

  @@map("training_plans")
}

model TrainingExercise {
  id             Int          @id @default(autoincrement())
  trainingPlanId Int          @map("training_plan_id")
  exerciseName   String       @map("exercise_name")
  sets           Int
  reps           Int
  restTime       String       @map("rest_time") 
  notes          String?      @db.Text

  trainingPlan   TrainingPlan @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)

  @@map("training_exercises")
}

// 🔥 3. ADICIONADO: Biblioteca Global de Exercícios (Imagens/GIFs)
// Gerido pelo Admin, lido pelo PT ao criar treinos, consultado pelo Guest.
model GlobalExercise {
  id          Int      @id @default(autoincrement())
  name        String   @unique // Ex: "Supino Inclinado com Halteres"
  gifUrl      String?  @map("gif_url") // Guarda o link ou caminho do ficheiro (Ex: "/uploads/supino.gif")
  category    String   // Ex: "Peito", "Costas", "Pernas"
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("global_exercises")
}

model WhatsappLog {
  id           Int      @id @default(autoincrement())
  studentId    Int      @map("student_id")
  message      String   @db.Text
  status       String   
  errorMessage String?  @map("error_message") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("whatsapp_logs")
}

model WeightLog {
  id           Int      @id @default(autoincrement())
  studentId    Int      @map("student_id")
  exerciseName String   @map("exercise_name")
  weight       Float    
  repsDone     Int?     @map("reps_done") 
  createdAt    DateTime @default(now()) @map("created_at")

  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("weight_logs")
}