// 1. Configuração do Gerador do Cliente Prisma (Padrão de Indústria)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// 🔥 1. ADICIONADO: Níveis de acesso válidos para o Controlo de Acessos (RBAC)
enum Role {
  ADMIN
  PT
  GUEST
}

// Definição dos modelos de dados

model UserAdmin {
  id             Int       @id @default(autoincrement())
  email          String    @unique
  nome          String    
  passwordHash   String    @map("password_hash")
  role           Role      @default(PT)
  createdAt      DateTime  @default(now()) @map("created_at") 
  lastLogin      DateTime? @map("last_login")
  failedAttempts Int       @default(0) @map("failed_attempts")
  isActive       Boolean   @default(true) @map("is_active")
  mustChangePassword Boolean @default(true) @map("must_change_password")

  students       Student[] 
  exercises          GlobalExercise[]
  @@map("users_admin")
}

model Student {
  id            Int            @id @default(autoincrement())
  userAdminId   Int            @map("user_admin_id") // 🔥 Liga este aluno ao seu PT criador
  fullName      String         @map("full_name")
  phoneNumber   String         @map("phone_number")
  status        String         @default("Ativo")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  userAdmin     UserAdmin      @relation(fields: [userAdminId], references: [id], onDelete: Cascade)

  trainingPlans TrainingPlan[]
  whatsappLogs  WhatsappLog[]
  weightLogs    WeightLog[]

  @@map("students")
}

model TrainingPlan {
  id        Int        @id @default(autoincrement())
  studentId Int        @map("student_id")
  notes     String?    @db.Text
  createdAt DateTime   @default(now()) @map("created_at")

  student   Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exercises TrainingExercise[]

  @@map("training_plans")
}

model TrainingExercise {
  id             Int          @id @default(autoincrement())
  trainingPlanId Int          @map("training_plan_id")
  exerciseName   String       @map("exercise_name")
  sets           Int
  reps           Int
  restTime       String       @map("rest_time") 
  notes          String?      @db.Text

  trainingPlan   TrainingPlan @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)

  @@map("training_exercises")
}

// 3. ADICIONADO: Biblioteca Global de Exercícios (Imagens/GIFs)

model GlobalExercise {
  id          Int        @id @default(autoincrement())
  name        String     @unique // Ex: "Supino Inclinado com Halteres"
  gifUrl      String?    @map("gif_url")
  category    String     // Ex: "Peito", "Costas", "Pernas"
  
  // 🔥 ADICIONADO: Ligação opcional com o PT (UserAdmin)
  userAdminId Int?       @map("user_admin_id")
  userAdmin   UserAdmin? @relation(fields: [userAdminId], references: [id], onDelete: Cascade)

  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("global_exercises")
}

model WhatsappLog {
  id           Int      @id @default(autoincrement())
  studentId    Int      @map("student_id")
  message      String   @db.Text
  status       String   
  errorMessage String?  @map("error_message") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("whatsapp_logs")
}

model WeightLog {
  id           Int      @id @default(autoincrement())
  studentId    Int      @map("student_id")
  exerciseName String   @map("exercise_name")
  weight       Float    
  repsDone     Int?     @map("reps_done") 
  createdAt    DateTime @default(now()) @map("created_at")

  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("weight_logs")
}

// 🔥 4. ADICIONADO: Registo de Solicitações de Acesso à Plataforma
// Guarda os pedidos enviados pelo formulário público para gestão do Admin.
model AccessRequest {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   // Não pomos @unique para permitir que a pessoa tente pedir outra vez se for recusada
  mensagem  String?  @db.Text
  status    String   @default("Pendente") // Valores: "Pendente", "Aprovado", "Recusado"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("access_requests")
}

model VerificationCode {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("verification_codes") // Mapeia para o nome exato da tabela no MariaDB
}